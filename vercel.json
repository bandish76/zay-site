{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/((?!.*\\.).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/apprentice.html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
