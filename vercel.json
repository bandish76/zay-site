{
  "rewrites": [
    { "source": "/apprentice", "destination": "/apprentice.html" },
    { "source": "/((?!.*\\.).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/apprentice",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/apprentice.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
